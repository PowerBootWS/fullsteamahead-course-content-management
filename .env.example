# GoHighLevel API Configuration
GOHIGHLEVEL_API=your-ghl-api-key
GOHIGHLEVEL_LOCATION_ID=your-location-id

# Vimeo API Configuration
# Option 1: Personal Access Token (recommended for MCP)
VIMEO_ACCESS_TOKEN=your-vimeo-personal-access-token

# Option 2: OAuth2 Client Credentials (used if VIMEO_ACCESS_TOKEN not set)
VIMEO_CLIENT_ID=your-vimeo-client-id
VIMEO_CLIENT_SECRET=your-vimeo-client-secret
VIMEO_AUTHORIZE_URL=https://api.vimeo.com/oauth/authorize
VIMEO_ACCESS_TOKEN_URL=https://api.vimeo.com/oauth/access_token

# Course Import (optional - can be passed via CLI)
# COURSE_TITLE=2nd Class Part B Paper 1
